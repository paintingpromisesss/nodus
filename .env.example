# mihomo
MIHOMO_TZ=Europe/Moscow

# cobalt
COBALT_API_URL=http://mihomo:9000
COBALT_API_PORT=9000
COBALT_NO_PROXY=localhost,127.0.0.1,::1,cobalt,mihomo,host.docker.internal
COBALT_CORS_WILDCARD=0
COBALT_API_AUTH_REQUIRED=0
COBALT_FORCE_LOCAL_PROCESSING=never
COBALT_DISABLED_SERVICES=bilibili,dailymotion,loom,newgrounds,snapchat,soundcloud,streamable,tumblr,vimeo,xiaohongshu,bluesky
COBALT_DURATION_LIMIT=10800
COBALT_TUNNEL_LIFESPAN=90
COBALT_RATELIMIT_WINDOW=60
COBALT_RATELIMIT_MAX=120
COBALT_TUNNEL_RATELIMIT_WINDOW=60
COBALT_TUNNEL_RATELIMIT_MAX=120
COBALT_ENABLE_DEPRECATED_YOUTUBE_HLS=never
COBALT_YOUTUBE_ALLOW_BETTER_AUDIO=0

# tg_bot
TG_BOT_TOKEN=123456789:bot_token_here
TG_BOT_API_URL=http://127.0.0.1:8081
TG_BOT_LOCAL_FILE_MODE=1
TG_BOT_COBALT_BASE_URL=http://mihomo:9000/
TG_BOT_MAX_FILE_BYTES=2147483648
TG_BOT_DB_PATH=./data/bot.db
TG_BOT_TEMP_DIR=./tmp
TG_BOT_REQUEST_TIMEOUT=30s
TG_BOT_DOWNLOAD_TIMEOUT=10m
TG_BOT_FFPROBE_TIMEOUT=5s
TG_BOT_FFMPEG_TIMEOUT=30s
TG_BOT_TELEGRAM_SEND_TIMEOUT=10m
TG_BOT_YTDLP_MAX_MEDIA_DURATION_SECS=7200
TG_BOT_YTDLP_CURRENTLY_LIVE_AVAILABLE=0
TG_BOT_YTDLP_PLAYLIST_AVAILABLE=0
TG_BOT_YTDLP_USE_JS_RUNTIME=1
TG_BOT_PICKER_SESSION_MANAGER_TTL=10m
TG_BOT_PICKER_SESSION_MANAGER_CLEANUP_INTERVAL=3m
TG_BOT_LOG_LEVEL=info
TG_BOT_API_ID=<your_api_id_here>
TG_BOT_API_HASH=<your_api_hash_here>
